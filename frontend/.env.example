# ─── API ─────────────────────────────────────────────────────────────────────
# Backend FastAPI base URL. No trailing slash. Must INCLUDE /api so the
# adapter URLs (`/sites`, `/auth/whoami`) resolve correctly.
VITE_API_BASE_URL=http://localhost:8000/api

# ─── Adapter selection ──────────────────────────────────────────────────────
# 'true' → in-memory mock adapter (offline UI dev).
# anything else → HTTP adapter against VITE_API_BASE_URL. Production: false.
VITE_USE_MOCK=false

# Optional: fraction of mock calls that randomly fail, for resilience testing.
VITE_MOCK_FAIL_RATE=0

# ─── Supabase auth ──────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API.
# `URL` is the project URL, `ANON_KEY` is the *anon* key (safe in the browser).
# NEVER put the service-role key here — that's server-only.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=replace-me-with-the-anon-key

# Request timeout for outbound HTTP calls (ms)
VITE_API_TIMEOUT_MS=20000
