# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="Z-Matrix BD Platform"
API_PREFIX=/api
DEBUG=false
LOG_LEVEL=INFO

# Local-dev opt-ins (NEVER set these in production):
# - ALLOW_INSECURE_DEFAULTS lets the app boot with the placeholder JWT secret.
#   Without it the app refuses to start when SUPABASE_JWT_SECRET is unset (#80).
# - ENABLE_DOCS serves /api/docs + /api/openapi.json (off by default — the
#   schema is an attacker's site map, #111).
# - CORS_ALLOW_LOCALHOST allows http://localhost:5100-5199 origins (#110).
ALLOW_INSECURE_DEFAULTS=true
ENABLE_DOCS=true
CORS_ALLOW_LOCALHOST=true

# Comma-separated EXACT origins allowed by CORS ('*' is refused at boot).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional regex for preview URLs (e.g. Vercel):
# CORS_ORIGIN_REGEX=^https://<vercel-project>-[a-z0-9-]+\.vercel\.app$

# Workspace codes whose users may sign in WITHOUT a password (demo tenants
# only). Empty = every account needs a password (#83).
# PASSWORDLESS_DEMO_CODES=SAMPLE-8513

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# Use the *transaction pooler* connection string from the Supabase dashboard
# (Settings → Database → Connection string → URI) and replace the driver
# prefix with `postgresql+asyncpg://`.
#
# Example: postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# Connection-pool tuning (SQLAlchemy)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=300

# ─── Supabase Auth (JWT) ─────────────────────────────────────────────────────
# Get this from: Supabase dashboard → Project Settings → API → "JWT Secret".
# The legacy HS256-signed tokens (still default for self-hosted GoTrue and
# most Supabase projects) verify against this shared secret.
SUPABASE_JWT_SECRET=replace-me-with-the-supabase-jwt-secret

# Audience claim on Supabase-issued tokens. Default is "authenticated".
SUPABASE_JWT_AUDIENCE=authenticated

# Anonymous-role short-circuit. When true, requests with NO Authorization
# header are treated as the built-in demo user (handy for local UI dev).
# MUST be false in production.
ALLOW_ANON_DEMO_USER=false

# ─── Storage (LOI / site photos) ─────────────────────────────────────────────
# Supabase Storage bucket name and base URL. The backend never writes the
# anon key directly — it uses the SERVICE ROLE key server-side only.
SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-the-service-role-key
SUPABASE_STORAGE_BUCKET=site-files

# ─── Platform admin portal (/admin) ──────────────────────────────────────────
# No default (#80): the portal stays disabled (503) until this is set.
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=replace-me-with-a-strong-password
